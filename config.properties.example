# Copia questo file in WebContent/WEB-INF/config.properties
# e sostituisci i valori con le tue API key

# API key OpenWeatherMap — gratuita su https://openweathermap.org/api
openweathermap.api.key=LA_TUA_API_KEY_QUI

# API key Pexels — gratuita su https://www.pexels.com/api/
pexels.api.key=LA_TUA_API_KEY_QUI